{
  "id": "@SYS-TPL-001",
  "title": "Metadata Template",
  "schema": {
    "id": "string (pattern: ^@[A-Z]{3}-[A-Z]{3}-[0-9]{3}$)",
    "domain": "string",
    "layer": "enum [ARC, BLP, MTX, AUT, SYS, CAN]",
    "type": "string",
    "status": "enum [Draft, Active, Deprecated]",
    "depends_on": "array (ids)",
    "feeds": "array (ids)",
    "related_to": "array (ids)",
    "governed_by": "array (ids)",
    "tags": "array (strings)",
    "authority_level": "integer (1-4)"
  },
  "required_fields": [
    "id",
    "layer",
    "type",
    "authority_level"
  ]
}
